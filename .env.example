PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Scenario engine (see specs/scenario-engine.md § Runtime store and ref layout)
RUNTIME_REPO_PATH=var/runtime.git
FIXTURES_PATH=fixtures
APP_VERSION=0.0.0-dev
# APP_COMMIT_HASH=

# Git exposure (see specs/facade.md § Git exposure) — read-only smart-HTTP
# endpoint over the runtime repo. Unset GIT_EXPOSURE_TOKEN => the endpoint
# refuses every request (fail closed); set it to enable operator debugging
# access, e.g. `git -c http.extraHeader="Authorization: Bearer $TOKEN" fetch ...`
GIT_EXPOSURE_PATH=/git
# GIT_EXPOSURE_TOKEN=
