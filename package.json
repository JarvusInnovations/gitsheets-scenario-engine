{
  "name": "gitsheets-scenario-engine",
  "description": "A scenario simulation backend template: a dual-mode Fastify API facade where git is the world-state engine (Fastify 5.x on Bun)",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/env": "^7.0.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "gitsheets": "~2.4.0",
    "pino-pretty": "^13.1.3"
  }
}
